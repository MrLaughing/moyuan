<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Moyuan" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/eink_black</item>
        <item name="colorPrimaryDark">@color/eink_black</item>
        <item name="colorAccent">@color/eink_black</item>
        <item name="colorOnPrimary">@color/eink_white</item>
        <item name="colorSurface">@color/bg_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSecondary">@color/text_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="materialButtonStyle">@style/MoyuanButton</item>
        <item name="textInputStyle">@style/MoyuanTextInput</item>
        <item name="editTextColor">@color/text_primary</item>
    </style>

    <style name="MoyuanButton" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/btn_bg</item>
        <item name="android:textColor">@color/btn_text</item>
        <item name="iconTint">@color/btn_text</item>
        <item name="cornerRadius">8dp</item>
        <item name="strokeColor">@color/btn_border</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:paddingTop">10dp</item>
        <item name="android:paddingBottom">10dp</item>
    </style>

    <style name="MoyuanButton.Primary" parent="MoyuanButton">
        <item name="android:backgroundTint">@color/eink_black</item>
        <item name="android:textColor">@color/eink_white</item>
        <item name="iconTint">@color/eink_white</item>
    </style>

    <style name="MoyuanButton.Outlined" parent="MoyuanButton">
        <item name="android:backgroundTint">@color/bg_primary</item>
        <item name="strokeColor">@color/eink_black</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/eink_black</item>
    </style>

    <style name="MoyuanTextInput" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:background">@drawable/bg_input</item>
        <item name="boxStrokeColor">@color/eink_black</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="MoyuanText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="MoyuanText.Title" parent="MoyuanText">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="MoyuanText.Heading" parent="MoyuanText">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="MoyuanText.Subheading" parent="MoyuanText">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="MoyuanText.Body" parent="MoyuanText">
        <item name="android:textSize">15sp</item>
    </style>

    <style name="MoyuanText.Caption" parent="MoyuanText">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="MoyuanText.Mono" parent="MoyuanText">
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
