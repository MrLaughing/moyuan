<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/bottom_nav_padding">

        <!-- 1. 解锁进度 -->
        <TextView
            android:id="@+id/tvUnlockProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp"
            android:text="已解锁 0/27"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <!-- 2. 搜索框 -->
        <LinearLayout
            android:id="@+id/searchBarContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingTop="12dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <!-- 放大镜图标 -->
            <ImageView
                android:id="@+id/ivSearchIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="搜索"
                android:src="@android:drawable/ic_menu_search" />

            <!-- 搜索输入框 -->
            <EditText
                android:id="@+id/etSearchPlant"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="搜索植物"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="14sp" />

            <!-- 清除按钮 -->
            <ImageView
                android:id="@+id/ivSearchClear"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="清除"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:visibility="gone" />
        </LinearLayout>

        <!-- 3. 路径筛选标签 -->
        <HorizontalScrollView
            android:id="@+id/hsvPathFilter"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/llPathTags"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- 全部 -->
                <TextView
                    android:id="@+id/tagAll"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_tag_active"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:text="全部"
                    android:textColor="@color/eink_white"
                    android:textSize="13sp" />

                <!-- 积墨 -->
                <TextView
                    android:id="@+id/tagJimo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:text="@string/path_jimo"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <!-- 秉烛 -->
                <TextView
                    android:id="@+id/tagBingzhu"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:text="@string/path_bingzhu"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <!-- 岁寒 -->
                <TextView
                    android:id="@+id/tagSuihan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:text="@string/path_suihan"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <!-- 寻芳 -->
                <TextView
                    android:id="@+id/tagXunfang"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:text="@string/path_xunfang"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <!-- 隐藏 -->
                <TextView
                    android:id="@+id/tagHidden"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_tag_inactive"
                    android:paddingStart="16dp"
                    android:paddingTop="8dp"
                    android:paddingEnd="16dp"
                    android:paddingBottom="8dp"
                    android:text="@string/path_hidden"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />
            </LinearLayout>
        </HorizontalScrollView>

        <!-- 4. 植物网格（三列） -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/catalogRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:nestedScrollingEnabled="false" />

        <!-- 空状态 -->
        <LinearLayout
            android:id="@+id/emptyCatalogContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="60dp"
            android:layout_marginEnd="16dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/emptyCatalogText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="还没有植物"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="同步阅读数据后会在这里看到你的植物"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
