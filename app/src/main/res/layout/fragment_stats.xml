<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/titleStats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="阅读统计"
        android:textColor="#000000"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ScrollView
        android:id="@+id/statsScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/titleStats"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/totalMinutes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:typeface="monospace"
                android:padding="12dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/todayMinutes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="14sp"
                android:typeface="monospace"
                android:padding="10dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/thisWeekMinutes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="14sp"
                android:typeface="monospace"
                android:padding="10dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/thisMonthMinutes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="14sp"
                android:typeface="monospace"
                android:padding="10dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/thisYearMinutes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="14sp"
                android:typeface="monospace"
                android:padding="10dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/streakDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="14sp"
                android:typeface="monospace"
                android:padding="10dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/maxStreakDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="14sp"
                android:typeface="monospace"
                android:padding="10dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/readDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="14sp"
                android:typeface="monospace"
                android:padding="10dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/nightReadDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="14sp"
                android:typeface="monospace"
                android:padding="10dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/finishBooksCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="14sp"
                android:typeface="monospace"
                android:padding="10dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/noteCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="14sp"
                android:typeface="monospace"
                android:padding="10dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/highlightCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="14sp"
                android:typeface="monospace"
                android:padding="10dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="16dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/preferCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="14sp"
                android:typeface="monospace"
                android:padding="10dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/preferAuthor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="14sp"
                android:typeface="monospace"
                android:padding="10dp"
                android:background="#FFFFFF"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/depthLevel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:typeface="monospace"
                android:padding="12dp"
                android:background="#EEEEEE"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/depthDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#333333"
                android:textSize="13sp"
                android:typeface="monospace"
                android:padding="12dp"
                android:background="#FFFFFF" />

        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/loadingView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/errorView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="加载失败，请检查网络或API Key"
        android:textColor="#CC0000"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
