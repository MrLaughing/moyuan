<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">
    <TextView
        android:id="@+id/titleProfile"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/nav_profile"
        android:textColor="#000000"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <TextView
        android:id="@+id/profileStats"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#000000"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/titleProfile"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp" />
    <EditText
        android:id="@+id/apiKeyInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:hint="微信读书 API Key"
        android:textColor="#000000"
        android:inputType="textPassword"
        android:fontFamily="monospace"
        app:layout_constraintTop_toBottomOf="@id/profileStats"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/toggleVisibilityButton"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp" />
    <Button
        android:id="@+id/toggleVisibilityButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="显示"
        android:textColor="#000000"
        android:minWidth="0dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintTop_toTopOf="@id/apiKeyInput"
        app:layout_constraintBottom_toBottomOf="@id/apiKeyInput"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="16dp" />
    <Button
        android:id="@+id/saveApiKeyButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="保存"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/apiKeyInput"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp" />
    <TextView
        android:id="@+id/saveFeedbackText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#000000"
        android:textSize="14sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/saveApiKeyButton"
        app:layout_constraintBottom_toBottomOf="@id/saveApiKeyButton"
        app:layout_constraintStart_toEndOf="@id/saveApiKeyButton"
        android:layout_marginStart="16dp" />
</androidx.constraintlayout.widget.ConstraintLayout>
